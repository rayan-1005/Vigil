# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://upiguard:secret@localhost:5432/upiguard_db

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────
# MUST be >= 64 characters. Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING_USE_OPENSSL_RAND_HEX_64_XXXXXXXXXX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Hugging Face ──────────────────────────────────────────────────────────
HF_API_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN
HF_TIMEOUT_MS=5000
HF_RETRY_ATTEMPTS=1

# ── Security ──────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
# MUST be >= 32 characters. Generate with: openssl rand -hex 32
API_KEY_SALT=REPLACE_WITH_32_CHAR_RANDOM_STRING_USE_OPENSSL_RAND_HEX_32_XXXXXX
CORS_ORIGIN=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=60
RATE_LIMIT_AUTH_MAX=300

# ── SSE ───────────────────────────────────────────────────────────────────
SSE_STREAM_TOKEN_TTL_S=30
